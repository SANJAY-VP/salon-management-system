# ─── API (required on Vercel) ─────────────────────────────────────────────────
# Your Render backend URL, no trailing slash.
# VITE_API_BASE_URL=https://your-service.onrender.com

# ─── Images ───────────────────────────────────────────────────────────────────
# Optional. Only needed if you store bare filenames and serve from a CDN base.
# With Cloudinary, the API returns full https URLs — you can leave this empty.
# VITE_CDN_BASE_URL=https://res.cloudinary.com/your-cloud/image/upload
