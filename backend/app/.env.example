# Database — SQLite (local) or PostgreSQL (Render / Aiven / RDS)
DATABASE_URL=sqlite:///./salon.db
# PostgreSQL examples (use the URI from your provider; often includes ?sslmode=require)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require
# Render may provide postgres://... — the app normalizes it to postgresql://

# App
APP_NAME=Salon Management System
APP_VERSION=1.0.0
DEBUG=True

# JWT
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated, no spaces required. Add your Vercel production URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Public URL of this API (used only when CLOUDINARY_URL is unset — local disk uploads)
API_PUBLIC_URL=http://localhost:8000

# Cloudinary — optional. If set, uploads go to CDN and /uploads static mount is disabled.
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Redis / Celery (optional locally)
REDIS_URL=redis://localhost:6379/0

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
